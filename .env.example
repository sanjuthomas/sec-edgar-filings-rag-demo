# Required by the SEC for programmatic EDGAR access.
SEC_USER_AGENT=Your Name your.email@example.com

# Host directories for persistent data (bind-mounted into containers).
# Defaults below are relative to this repo — override with any path you prefer.
#
# Examples:
#   EDGAR_HOST_PATH=./data/edgar
#   EDGAR_HOST_PATH=/Volumes/Transcend/edgar
#   EDGAR_HOST_PATH=$HOME/sec-edgar-data/edgar
EDGAR_HOST_PATH=./data/edgar
MONGO_HOST_PATH=./data/mongo-data
KAFKA_HOST_PATH=./data/kafka-data
PGVECTOR_HOST_PATH=./data/pgvector-data
