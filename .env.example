# Required by the SEC for programmatic EDGAR access.
SEC_USER_AGENT=thomas.sanju@gmail.com
WIKIPEDIA_USER_AGENT=thomas.sanju@gmail.com

# Host directories for persistent data (bind-mounted into containers).
# Defaults below are relative to this repo — override with any path you prefer.
#
# Example test deployment root:
#   LOCAL_DATA_ROOT=/Users/you/work/sec-edgar-rag-demo-test/sec-edgar
#   EDGAR_HOST_PATH=${LOCAL_DATA_ROOT}/filings-data
#   ...
LOCAL_DATA_ROOT=./sec-edgar
EDGAR_HOST_PATH=${LOCAL_DATA_ROOT}/filings-data
MONGO_HOST_PATH=${LOCAL_DATA_ROOT}/mongo-data
KAFKA_HOST_PATH=${LOCAL_DATA_ROOT}/kafka-data
PGVECTOR_HOST_PATH=${LOCAL_DATA_ROOT}/pgvector-data
QDRANT_HOST_PATH=${LOCAL_DATA_ROOT}/qdrant-data
# Shared HuggingFace model cache for ETL + search (BGE-M3 is ~2.3 GB).
HF_CACHE_HOST_PATH=${LOCAL_DATA_ROOT}/hf-cache
# Shared embedding backend config (embedded vs Ollama) for ETL + search UIs.
CONFIG_HOST_PATH=./config

# Compose profiles — which vector pipelines to start (comma-separated).
# Full demo (default): pgvector,qdrant,rag  (rag = chat UI)
# pgvector only:       pgvector
# Qdrant only:         qdrant
COMPOSE_PROFILES=pgvector,qdrant,rag
