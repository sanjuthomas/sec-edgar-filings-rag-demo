# Required by the SEC for programmatic EDGAR access.
SEC_USER_AGENT=thomas.sanju@gmail.com
WIKIPEDIA_USER_AGENT=thomas.sanju@gmail.com

# Host directories for persistent data (bind-mounted into containers).
# Defaults below are relative to this repo — override with any path you prefer.
#
# Examples:
#   EDGAR_HOST_PATH=./sec-edgar/filings-data
#   EDGAR_HOST_PATH=/Volumes/Transcend/edgar
#   EDGAR_HOST_PATH=$HOME/sec-edgar/filings-data
EDGAR_HOST_PATH=./sec-edgar/filings-data
MONGO_HOST_PATH=./sec-edgar/mongo-data
KAFKA_HOST_PATH=./sec-edgar/kafka-data
PGVECTOR_HOST_PATH=./sec-edgar/pgvector-data
QDRANT_HOST_PATH=./sec-edgar/qdrant-data
